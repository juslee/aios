{
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "default",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/setup-dev-env.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'doc-audit-needed'",
            "condition": "toolInput.file_path matches 'docs/**/*.md'"
          }
        ]
      },
      {
        "matcher": "mcp__obsidian__write_note|mcp__obsidian__patch_note",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'doc-audit-needed'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git pull *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git stash *)",
      "Bash(git rebase *)",
      "Bash(rustup *)",
      "Bash(just *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(objdump *)",
      "Bash(gh *)",
      "Bash(sleep *)",
      "Bash(git worktree *)",
      "Bash(git rm *)",
      "Bash(brew *)",
      "Bash(cd *)",
      "Bash(for *)",
      "Bash(python3 -c *)",
      "Bash(sed *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(awk *)",
      "Bash(touch *)",
      "Bash(echo *)",
      "Bash(pkill -f \"qemu-system-aarch64*)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf /)*"
    ]
  }
}
